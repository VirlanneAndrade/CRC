        <div class="topbar-actions">
          <button class="topbar-btn tour-btn" onclick="startTour()" title="Ajuda sobre esta tela" data-tour="tour-btn">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M9.09 9a3 3 0 015.83 1c0 2-3 3-3 3"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
          </button>
          <button class="topbar-btn notification-btn" onclick="navigate('notificacoes')">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 8A6 6 0 006 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 01-3.46 0"/></svg>
            <span class="notif-badge">3</span>
          </button>
          <div class="topbar-user" onclick="navigate('perfil')">
            <div class="avatar-sm" id="topbar-avatar">MF</div>
            <span class="topbar-username">Maria Fernanda</span>
          </div>
          <button class="topbar-btn topbar-logout-btn" onclick="doLogout()" title="Sair do sistema">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 21H5a2 2 0 01-2-2V5a2 2 0 012-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
          </button>
        </div>
      </header>
      <div id="page-container" class="page-container"></div>
    </main>
  </div>

  <!-- ====== MODAL BOLETO ====== -->
  <div id="modal-boleto" class="modal-overlay" style="display:none">
    <div class="modal modal-lg">
      <div class="modal-header"><h3>Boleto / PIX</h3><button class="modal-close" onclick="closeModal('modal-boleto')">&times;</button></div>
      <div class="modal-body" id="modal-boleto-body" style="max-height:70vh;overflow-y:auto"></div>
      <div class="modal-footer"><button class="btn btn-ghost btn-sm" onclick="closeModal('modal-boleto')">Fechar</button></div>
    </div>
  </div>

  <!-- ====== MODAIS ====== -->
  <div id="modal-notif" class="modal-overlay" style="display:none">
    <div class="modal modal-lg">
      <div class="modal-header"><h3>Central de Notificações</h3><button class="modal-close" onclick="closeModal('modal-notif')">&times;</button></div>
      <div class="modal-body">
        <div class="modal-robot-row"><div class="robot-container" id="robot-notif"></div><div class="robot-speech"><p>Configure <strong>alertas automáticos</strong> para nunca perder um vencimento!</p></div></div>
        <div class="notif-channel-grid">
          <label class="notif-channel-card"><input type="checkbox" class="notif-check" checked><div class="notif-channel-icon"><svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg></div><span class="notif-channel-name">E-mail</span></label>
          <label class="notif-channel-card"><input type="checkbox" class="notif-check"><div class="notif-channel-icon"><svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 11.5a8.38 8.38 0 01-.9 3.8 8.5 8.5 0 01-7.6 4.7 8.38 8.38 0 01-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 01-.9-3.8 8.5 8.5 0 014.7-7.6 8.38 8.38 0 013.8-.9h.5a8.48 8.48 0 018 8v.5z"/></svg></div><span class="notif-channel-name">WhatsApp</span></label>
          <label class="notif-channel-card"><input type="checkbox" class="notif-check"><div class="notif-channel-icon"><svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/></svg></div><span class="notif-channel-name">SMS</span></label>
        </div>
      </div>
      <div class="modal-footer"><button class="btn btn-ghost btn-sm" onclick="closeModal('modal-notif')">Agora não</button><button class="btn btn-primary btn-sm" onclick="localStorage.setItem('arrecada_notif_seen','1');closeModal('modal-notif')">Salvar</button></div>
    </div>
  </div>

  <!-- ====== TOUR ====== -->
  <div id="tour-overlay" class="tour-overlay" style="display:none">
    <div class="tour-spotlight" id="tour-spotlight"></div>
    <div class="tour-tooltip" id="tour-tooltip">
      <div class="tour-tooltip-robot" id="tour-robot"></div>
      <div class="tour-tooltip-content">
        <p class="tour-text" id="tour-text"></p>
        <div class="tour-actions"><span class="tour-counter" id="tour-counter"></span><div class="tour-btns"><button class="btn btn-ghost btn-sm" onclick="endTour()">Pular</button><button class="btn btn-primary btn-sm" id="tour-next-btn" onclick="nextTourStep()">Próximo</button></div></div>
      </div>
    </div>
  </div>

  <!-- ====== CHAT IA FLUTUANTE ====== -->
  <div id="robot-assistant" class="robot-floating" onclick="toggleChat()"><div class="robot-pulse"></div><div class="robot-body" id="robot-main"></div></div>
  <div id="chat-window" class="chat-window" style="display:none">
    <div class="chat-header">
      <div style="display:flex;align-items:center;gap:8px">
        <div id="robot-menu-icon" style="width:28px;height:28px"></div>
        <div><div style="font-size:.88rem;font-weight:700">Assistente CRC</div><div style="font-size:.68rem;color:rgba(255,255,255,.7)">Online — Pergunte sobre o Portal</div></div>
      </div>
      <button class="chat-close" onclick="toggleChat()">&times;</button>
    </div>
    <div class="chat-body" id="chat-body"></div>
    <div class="chat-footer">
      <input class="chat-input" id="chat-input" type="text" placeholder="Digite sua pergunta..." onkeydown="if(event.key==='Enter')sendChat()">
      <button class="chat-send" onclick="sendChat()"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg></button>
    </div>
  </div>

  <input type="file" id="photo-upload" accept="image/*" style="display:none" onchange="handlePhotoUpload(event)">
  <script src="/js/app.js"></script>
</body>
</html>
