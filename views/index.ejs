<body>

  <!-- ====== LOGIN ====== -->
  <div id="login-screen" class="screen active">
    <div class="login-bg">
      <div class="login-particles" id="particles"></div>

      <!-- TELA CONTRIBUINTE -->
      <div class="login-center" id="login-contribuinte">
        <div class="login-logo-svg">
          <svg viewBox="0 0 340 70" fill="none" xmlns="http://www.w3.org/2000/svg" class="logo-svg-main">
            <rect x="8" y="40" width="10" height="22" rx="3" fill="#00D4A0" opacity="0.5"/>
            <rect x="22" y="28" width="10" height="34" rx="3" fill="#00D4A0" opacity="0.7"/>
            <rect x="36" y="14" width="10" height="48" rx="3" fill="#00D4A0"/>
            <path d="M41 14 L41 5 L48 12" stroke="#00D4A0" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
            <circle cx="41" cy="4" r="2" fill="#00D4A0" opacity="0.6"><animate attributeName="opacity" values="0.6;1;0.6" dur="2s" repeatCount="indefinite"/></circle>
            <text x="58" y="38" fill="#00D4A0" font-size="24" font-weight="900" font-family="Inter, sans-serif" letter-spacing="-0.3">CRC</text>
            <text x="58" y="56" fill="#00D4A0" font-size="8" font-family="Inter, sans-serif" font-weight="400" opacity="0.55">Central de Relacionamento com o Contribuinte</text>
          </svg>
        </div>
        <div class="login-card">
          <div class="login-card-header">
            <h2>Portal do Contribuinte</h2>
            <p>Município de Lauro de Freitas — Bahia</p>
          </div>
          <button class="btn btn-govbr" onclick="doLogin()" style="margin-bottom:12px">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M15 3h4a2 2 0 012 2v14a2 2 0 01-2 2h-4"/><polyline points="10 17 15 12 10 7"/><line x1="15" y1="12" x2="3" y2="12"/></svg>
            Entrar com Gov.BR
          </button>
          <p style="font-size:.78rem;color:var(--text-muted);text-align:center;line-height:1.5;margin-top:8px">Acesso exclusivo via <strong>Gov.BR</strong>.<br>Se você é procurador, acesse com seu próprio Gov.BR e a procuração será carregada automaticamente.</p>
          <div class="login-links" style="margin-top:12px"><a href="https://www.gov.br/governodigital/pt-br/conta-gov-br" target="_blank">O que é Gov.BR?</a><a href="https://acesso.gov.br" target="_blank">Criar conta Gov.BR</a></div>
        </div>
        <button class="login-switch-btn" onclick="switchToAdminLogin()">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 00.33 1.82l.06.06a2 2 0 010 2.83 2 2 0 01-2.83 0l-.06-.06a1.65 1.65 0 00-1.82-.33 1.65 1.65 0 00-1 1.51V21a2 2 0 01-4 0v-.09A1.65 1.65 0 009 19.4a1.65 1.65 0 00-1.82.33l-.06.06a2 2 0 01-2.83-2.83l.06-.06A1.65 1.65 0 004.68 15a1.65 1.65 0 00-1.51-1H3a2 2 0 010-4h.09A1.65 1.65 0 004.6 9a1.65 1.65 0 00-.33-1.82l-.06-.06a2 2 0 012.83-2.83l.06.06A1.65 1.65 0 009 4.68a1.65 1.65 0 001-1.51V3a2 2 0 014 0v.09a1.65 1.65 0 001 1.51 1.65 1.65 0 001.82-.33l.06-.06a2 2 0 012.83 2.83l-.06.06A1.65 1.65 0 0019.4 9a1.65 1.65 0 001.51 1H21a2 2 0 010 4h-.09a1.65 1.65 0 00-1.51 1z"/></svg>
          Acesso administrativo
        </button>
        <p class="login-footer-text">v1.0 — Central de Relacionamento com o Contribuinte</p>
      </div>

      <!-- TELA ADMIN -->
      <div class="login-center login-hidden" id="login-admin">
        <div class="login-logo-svg">
          <svg viewBox="0 0 340 70" fill="none" xmlns="http://www.w3.org/2000/svg" class="logo-svg-main" style="filter:drop-shadow(0 2px 20px rgba(232,124,30,.35)) drop-shadow(0 0 40px rgba(232,124,30,.1))">
            <rect x="8" y="40" width="10" height="22" rx="3" fill="#E87C1E" opacity="0.5"/>
            <rect x="22" y="28" width="10" height="34" rx="3" fill="#E87C1E" opacity="0.7"/>
            <rect x="36" y="14" width="10" height="48" rx="3" fill="#E87C1E"/>
            <path d="M41 14 L41 5 L48 12" stroke="#E87C1E" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
            <circle cx="41" cy="4" r="2" fill="#E87C1E" opacity="0.6"><animate attributeName="opacity" values="0.6;1;0.6" dur="2s" repeatCount="indefinite"/></circle>
            <text x="58" y="38" fill="#E87C1E" font-size="24" font-weight="900" font-family="Inter, sans-serif" letter-spacing="-0.3">CRC</text>
            <text x="58" y="56" fill="#E87C1E" font-size="8" font-family="Inter, sans-serif" font-weight="400" opacity="0.55">Painel Administrativo</text>
          </svg>
        </div>
        <div class="login-card" style="border-color:rgba(232,124,30,.35)">
          <div class="login-card-header">
            <h2 style="color:#E87C1E">Acesso Administrativo</h2>
            <p>Suporte, desenvolvimento e administradores</p>
          </div>
          <div class="form-group"><label>Login</label><input type="text" placeholder="Usuário" class="form-input" id="admin-login-user" autocomplete="username"></div>
          <div class="form-group"><label>Senha</label><input type="password" placeholder="••••••••" class="form-input" id="admin-login-pass" onkeydown="if(event.key==='Enter')doAdminLogin()" autocomplete="current-password"></div>
          <button class="btn btn-primary" style="background:#E87C1E;color:#fff" onclick="doAdminLogin()">Entrar como Admin</button>
        </div>
        <button class="login-switch-btn" onclick="switchToContribLogin()">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="15 18 9 12 15 6"/></svg>
          Voltar para Portal do Contribuinte
        </button>
        <p class="login-footer-text">v1.0 — Central de Relacionamento com o Contribuinte</p>
      </div>

    </div>
  </div>

