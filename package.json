{
  "name": "crc-portal-contribuinte",
  "version": "1.0.0",
  "description": "CRC — Central de Relacionamento com o Contribuinte — Município de Lauro de Freitas",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "test": "node --test tests/unit/*.test.js tests/integration/*.test.js",
    "test:watch": "node --test --watch tests/unit/*.test.js tests/integration/*.test.js",
    "test:e2e": "node --test tests/e2e/*.spec.js",
    "doc:integracao:pdf": "node gerar-documento-integracao-pdf.js",
    "doc:ativacao:pdf": "node gerar-doc-integracao-ativacao-pdf.js",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:seed": "prisma db seed",
    "db:studio": "prisma studio",
    "db:status": "prisma migrate status",
    "db:baseline": "node scripts/prisma-baseline.js"
  },
  "prisma": {
    "seed": "node prisma/seed.js"
  },
  "dependencies": {
    "@prisma/client": "^6.19.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.0",
    "ejs": "^3.1.10",
    "express": "^4.21.0",
    "express-rate-limit": "^8.1.0",
    "express-session": "^1.18.0",
    "helmet": "^8.1.0",
    "morgan": "^1.10.0",
    "pdfkit": "^0.17.2",
    "pino": "^10.0.0",
    "pino-http": "^11.0.0"
  },
  "devDependencies": {
    "prisma": "^6.19.3"
  }
}
