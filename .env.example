NODE_ENV=development
PORT=4001
SESSION_SECRET=trocar_em_producao

# Fase 1 - seguranca/base
CORS_ORIGIN=http://localhost:4001
RATE_LIMIT_PUBLIC=200
LOG_LEVEL=info

# Banco local (PostgreSQL na maquina, fora do Docker)
# Dev local: localhost ou IP LAN. Deploy Docker: use IP LAN da maquina (ex.: 10.0.6.3)
# Formato: postgresql://USUARIO:SENHA@HOST:PORTA/BANCO
DATABASE_URL=postgresql://postgres:SUA_SENHA@localhost:5432/crc_portal
REDIS_URL=redis://localhost:6379

# DTE + integracao EQFIS
EQFIS_API_BASE_URL=http://localhost:3000/api/dte
EQFIS_API_KEY=
EQFIS_TIMEOUT_MS=10000

# Integracao com a API JFU (Webrun/SIFMP)
# Ex.: http://177.8.224.178:4090/sifmp
TRIBUTOS_API_BASE_URL=
TRIBUTOS_API_KEY=
# JFU usa x-api-key (header X-API-Key)
TRIBUTOS_AUTH_TYPE=x-api-key
TRIBUTOS_TIMEOUT_MS=10000
