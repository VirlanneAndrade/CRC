NODE_ENV=development
PORT=4001
SESSION_SECRET=trocar_em_producao

# Fase 1 - seguranca/base
CORS_ORIGIN=http://localhost:4001
RATE_LIMIT_PUBLIC=200
LOG_LEVEL=info

# Fundacao para proximas fases
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/crc_portal
REDIS_URL=redis://localhost:6379

# DTE + integracao EQFIS
EQFIS_API_BASE_URL=http://localhost:3000/api/dte
EQFIS_API_KEY=
EQFIS_TIMEOUT_MS=10000

# Integracao com a API da empresa de Tributos
# Preencher com os dados que a empresa de tributos entregar (homologacao primeiro)
TRIBUTOS_API_BASE_URL=
TRIBUTOS_API_KEY=
# bearer | x-api-key | none
TRIBUTOS_AUTH_TYPE=bearer
TRIBUTOS_TIMEOUT_MS=10000
